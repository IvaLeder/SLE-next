# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.image-backups/
compress-images.mjs
restore-larger-than-original.mjs
convert-gifs.mjs
audit-image-sizes.mjs
dev-quickstart.md
BACKLOG.md

# asset pipeline (npm run images / assets) — generated variants + manifest are
# rebuilt by the prebuild hook; the encode cache lives in node_modules/.cache
/public/images/_opt/
/src/lib/assets/manifest.json

# Social-media image exports (generated on demand, not part of the site)
social-exports/
